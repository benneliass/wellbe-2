        "description": "Lifecycle states for a Health Thread.\n\nDefined in docs/system-design/health_thread_state_machine.md.",
        "enum": [
          "draft",
          "active_unresolved",
          "waiting_for_result",
          "referred",
          "watchful_waiting",
          "escalated",
          "explained",
          "chronic_monitoring",
          "closed",
          "reopened",
          "archived"
        ],
        "title": "HealthThreadStatus",
        "type": "string"
      },
