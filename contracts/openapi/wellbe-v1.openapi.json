        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "patient_id": {
            "title": "Patient Id",
            "type": "string"
          },
          "schema_version": {
            "default": "c13.health_thread.v1",
            "title": "Schema Version",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "status_version": {
            "title": "Status Version",
            "type": "integer"
          },
          "thread_id": {
            "title": "Thread Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "thread_id",
          "patient_id",
          "title",
          "status",
          "status_version",
          "created_at",
          "updated_at"
        ],
        "title": "ThreadV1",
        "type": "object"
      },
