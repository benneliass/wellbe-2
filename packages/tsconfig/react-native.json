{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "WellBe React Native (Expo)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "verbatimModuleSyntax": false
  }
}
